[Unit]
Description=Antigravity -> OpenAI bridge
After=network.target

[Service]
Type=simple
User=%USER%
WorkingDirectory=%WORK_DIR%
Environment="PATH=%PYTHON_BIN_DIR%:%HOME%/.local/bin:/usr/local/bin:/usr/bin:/bin"
EnvironmentFile=-%WORK_DIR%/.env
ExecStart=%PYTHON_BIN_DIR%/python3 %WORK_DIR%/server.py --host 0.0.0.0 --port %PORT%
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target

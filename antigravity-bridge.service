[Unit]
Description=Antigravity -> OpenAI bridge
After=network.target

[Service]
Type=simple
User=%USER%
WorkingDirectory=%WORK_DIR%
Environment="PATH=%PYTHON_BIN_DIR%:/usr/local/bin:/usr/bin:/bin"
Environment="PORT=%PORT%"
Environment="BRIDGE_API_KEY=%BRIDGE_API_KEY%"
Environment="ANTIGRAVITY_CONST=%ANTIGRAVITY_CONST%"
Environment="ANTIGRAVITY_ACCOUNTS=%ANTIGRAVITY_ACCOUNTS%"
Environment="ANTIGRAVITY_AUTH=%ANTIGRAVITY_AUTH%"
ExecStart=%PYTHON_BIN_DIR%/python3 %WORK_DIR%/server.py --host 0.0.0.0 --port %PORT%
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target

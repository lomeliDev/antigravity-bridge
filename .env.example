# Antigravity Bridge — example configuration
# Copy to .env and fill in your values.

# ── Server ─────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=52847

# ── OAuth (required) ──────────────────────────────────────────
# Google OAuth client credentials from the opencode-antigravity-auth npm package.
# These are public values (desktop OAuth uses PKCE, not client secrets).
# Find them in the package's constants.js or set your own.
ANTIGRAVITY_CLIENT_ID=
ANTIGRAVITY_CLIENT_SECRET=

# Your OAuth refresh_token — get it via: python3 auth-login.py
BRIDGE_REFRESH_TOKEN=

# ── Optional ──────────────────────────────────────────────────
# Set an API key to require client authentication (Authorization: Bearer <key>)
# BRIDGE_API_KEY=your-random-key-here

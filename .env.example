# Antigravity Bridge — example configuration
# Copy to .env and fill in your values.

# ── Server ─────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=52847

# ── OAuth (required) ──────────────────────────────────────────
# Google OAuth client credentials from the opencode-antigravity-auth npm package.
# These are public values (desktop OAuth uses PKCE, not client secrets).
ANTIGRAVITY_CLIENT_ID=
ANTIGRAVITY_CLIENT_SECRET=

# Your OAuth refresh_token — get it via: python3 auth-login.py
BRIDGE_REFRESH_TOKEN=

# ── Client authentication (single-account mode) ────────────────
# Require clients to send: Authorization: Bearer *** *
# BRIDGE_API_KEY=sk-your-random-key

# ── Admin protection ──────────────────────────────────────────
# Protects /admin/* endpoints. If empty → open access (dev mode).
# Set this in production: Authorization: Bearer <admin_key>
# BRIDGE_ADMIN_KEY=sk-admin-secret

# ── Multi-account ─────────────────────────────────────────────
# Path to the multi-account config file (JSON).
# BRIDGE_ACCOUNTS_FILE=./accounts.json

# Directory for per-account access token caches.
# BRIDGE_AUTH_CACHE_DIR=./auth_cache
